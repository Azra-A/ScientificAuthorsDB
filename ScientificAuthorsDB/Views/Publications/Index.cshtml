@model IEnumerable<ScientificAuthorsDB.Models.Publication>
@{
    ViewData["Title"] = "Публикации";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📄 Научни публикации</h2>
    <a asp-action="Create" class="btn btn-success">+ Нова публикация</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-4 p-3 bg-light rounded shadow-sm">
    <div class="col-md-6">
        <input type="text" name="searchTitle" value="@ViewData["SearchTitle"]" class="form-control" placeholder="Търси по заглавие..." />
    </div>
    <div class="col-md-3">
        <select name="searchType" class="form-select">
            <option value="">-- Всички типове --</option>
            <option value="Научна статия">Научна статия</option>
            <option value="Монография">Монография</option>
            <option value="Доклад">Доклад</option>
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary w-100">🔍 Търси</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
    </div>
</form>

<div class="row">
    @foreach (var pub in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card h-100 border-start border-primary border-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark">@pub.Title</h5>
                    <h6 class="card-subtitle mb-2 text-muted">📅 @pub.Year | @pub.PublicationType</h6>
                    <p class="card-text">
                        <strong>Автори:</strong>
                        @string.Join(", ", pub.AuthorPublications.Select(ap => ap.Author.FullName))
                    </p>
                    <div class="mb-3">
                        @foreach (var pf in pub.PublicationFields)
                        {
                            <span class="badge rounded-pill bg-success me-1">@pf.ResearchField.Name</span>
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0 d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@pub.Id" class="btn btn-sm btn-outline-info">Детайли</a>
                    <a asp-action="Edit" asp-route-id="@pub.Id" class="btn btn-sm btn-outline-warning">Редактирай</a>
                    <a asp-action="Delete" asp-route-id="@pub.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                </div>
            </div>
        </div>
    }
</div>