@model ScientificAuthorsDB.Models.Author
@{
    ViewData["Title"] = "Нов автор";
}

<h2>Нов автор</h2>
<hr />
<form asp-action="Create" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="col-12 text-danger"></div>
    <div class="col-md-6">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="OrcidId" class="form-label"></label>
        <input asp-for="OrcidId" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="BirthYear" class="form-label"></label>
        <input asp-for="BirthYear" class="form-control" />
    </div>
    <div class="col-12">
        <label class="form-label fw-bold">Институции (задръжте Ctrl за избор на повече от една)</label>
        <select name="selectedInstitutions" asp-items="ViewBag.Institutions" class="form-select" multiple size="5"></select>
    </div>
    <div class="col-12 mt-4">
        <button type="submit" class="btn btn-success">Запази</button>
        <a asp-action="Index" class="btn btn-secondary">Отказ</a>
    </div>
</form>