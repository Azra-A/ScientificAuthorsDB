<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Научна база данни</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-uppercase tracking-wider" asp-controller="Home" asp-action="Index">
                    Научна база данни
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto text-uppercase small fw-semibold">
                        <li class="nav-item border-end border-secondary px-2">
                            <a class="nav-link" asp-controller="Authors" asp-action="Index">Автори</a>
                        </li>
                        <li class="nav-item border-end border-secondary px-2">
                            <a class="nav-link" asp-controller="Institutions" asp-action="Index">Институции</a>
                        </li>
                        <li class="nav-item px-2">
                            <a class="nav-link" asp-controller="Publications" asp-action="Index">Публикации</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container mt-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>
    
    <footer class="bg-light text-muted py-4 mt-5 border-top">
        <div class="container">
            <div class="row justify-content-center text-center">
                <!-- Лява част: Име на проекта -->
                <div class="col-md-5 mb-3 mb-md-0">
                    <h6 class="text-dark mb-1 fw-bold text-uppercase">Научна информационна система</h6>
                    <p class="small mb-0">Университетски проект &copy; @DateTime.Now.Year</p>
                </div>
            
                <!-- Разделителна линия (само за по-големи екрани) -->
                <div class="col-md-1 d-none d-md-block border-start" style="height: 40px; width: 1px; margin-top: 5px;"></div>

                <!-- Дясна част: Контакти -->
                <div class="col-md-5">
                    <div class="d-inline-block text-start small">
                        <div class="mb-1"><strong>Тел:</strong> +359 888 123 456</div>
                        <div><strong>Имейл:</strong> contact@science-db.bg</div>
                    </div>
                </div>
            </div>
        </div>
    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>