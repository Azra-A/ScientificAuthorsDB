@model ScientificAuthorsDB.Models.Publication
@{
    ViewData["Title"] = "Изтриване";
}

<div class="alert alert-danger mt-4">
    <h3>🗑 Изтриване на публикация</h3>
    <p class="fs-5">Наистина ли искате да премахнете <strong>@Model.Title</strong> от базата данни?</p>
    <hr />
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger btn-lg">Да, изтрий</button>
        <a asp-action="Index" class="btn btn-light btn-lg">Не, върни ме обратно</a>
    </form>
</div>