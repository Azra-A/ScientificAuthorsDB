@model ScientificAuthorsDB.Models.Publication
@{
    ViewData["Title"] = "Редактирай публикация";
}

<h2>Редактиране на публикация</h2>
<hr />
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-3">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="FilePath" />
    
    <div class="col-md-12">
        <label asp-for="Title" class="form-label fw-bold">Заглавие</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="col-md-12">
        <label asp-for="Abstract" class="form-label fw-bold">Резюме</label>
        <textarea asp-for="Abstract" class="form-control" rows="4"></textarea>
    </div>

    <div class="col-md-8">
        <label asp-for="Journal" class="form-label fw-bold">Журнал / Издателство</label>
        <input asp-for="Journal" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="Year" class="form-label fw-bold">Година</label>
        <input asp-for="Year" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="PublicationType" class="form-label fw-bold">Тип</label>
        <select asp-for="PublicationType" class="form-select">
            <option value="">-- Изберете тип --</option>
            <option value="Научна статия">Научна статия</option>
            <option value="Монография">Монография</option>
            <option value="Доклад от конференция">Доклад от конференция</option>
            <option value="Книга">Книга</option>
            <option value="Дисертация">Дисертация</option>
        </select>
        <span asp-validation-for="PublicationType" class="text-danger"></span>
    </div>

    <div class="col-md-8">
        <label asp-for="Doi" class="form-label fw-bold">DOI номер </label>
        <input asp-for="Doi" class="form-control" />
        <span asp-validation-for="Doi" class="text-danger"></span>
    </div>

    <div class="col-md-12 mt-4 mb-3">
        <label class="form-label fw-bold">Прикачи нов файл (PDF/Word)</label>

        @if (!string.IsNullOrEmpty(Model.FilePath))
        {
            <div class="alert alert-info py-2 mb-2">
                <i class="bi bi-info-circle"></i> Текущ файл: <a href="@Model.FilePath" target="_blank" class="fw-bold">Преглед</a>.
                Ако изберете нов файл по-долу, той ще замени стария.
            </div>
        }

        <input type="file" name="uploadedFile" class="form-control" accept=".pdf,.doc,.docx" />
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold">Автори</label>
        <select name="selectedAuthors" asp-items="ViewBag.Authors" class="form-select" multiple size="6"></select>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold">Научни области</label>
        <select name="selectedFields" asp-items="ViewBag.Fields" class="form-select" multiple size="6"></select>
    </div>

    <div class="col-12 mt-4">
        <button type="submit" class="btn btn-warning">Обнови данните</button>
        <a asp-action="Index" class="btn btn-secondary">Отказ</a>
    </div>
</form>